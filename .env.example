# ═══════════════════════════════════════════════════
# PhytoScan AI — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS commiter le fichier .env sur Git
# ═══════════════════════════════════════════════════

# Clé secrète Django (générez une valeur longue et aléatoire)
# En ligne : https://djecrety.ir/
SECRET_KEY=django-insecure-changez-moi-en-production

# Mode débogage (True en développement, False en production)
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1

# Clé API Groq pour le chatbot PhytoBot
# Compte gratuit : https://console.groq.com
GROQ_API_KEY=

# URL de la base de données (laissez vide pour SQLite en développement)
# Render la fournit automatiquement en production
DATABASE_URL=
