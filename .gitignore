# ═══════════════════════════════════════════════════
# PhytoScan AI — .gitignore
# Django + Python + environnement Windows/Mac/Linux
# ═══════════════════════════════════════════════════

# ── Environnement Python ────────────────────────────
venv/
env/
.venv/
ENV/
*.egg-info/
dist/
build/
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Variables d'environnement (contient la clé secrète et la clé Groq) ──
.env
.env.local
.env.production
.env.staging
*.env

# ── Django ──────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
/media/uploads/

# ── Modèles ML (trop volumineux) ────────────────────
detection/models/*.onnx
detection/models/*.onnx.data
detection/models/*.pth

# ── Tests et coverage ───────────────────────────────
.coverage
.coverage.*
htmlcov/
.tox/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# ── Éditeurs et IDE ─────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter Notebooks ───────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Modèles ML (fichiers volumineux à gérer avec Git LFS si nécessaire) ──
*.h5
*.pkl
*.pickle
*.joblib
*.pt
*.pth
*.onnx
.env
# ── Fichiers système ─────────────────────────────────
__MACOSX/
.Spotlight-V100
.Trashes
ehthumbs.db

# ── Dossiers de déploiement ──────────────────────────
.heroku/
.render/
Procfile.local